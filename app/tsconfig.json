{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "noEmit": true, // or "emitDeclarationOnly": true
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
